# This file tells the computer which files should NOT be saved to the online code storage
# It's like a filter to keep messy or secret files out of your project history

# These are the folders that hold the heavy engine parts of your project
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# This ignores the reports created when you test your code
/coverage

# This ignores the temporary files created when the website is building or running
/.next/
/out/

# This ignores the final version of the site meant for the internet
/production
/build

# These ignore tiny system files or security keys that aren't part of the code
.DS_Store
*.pem

# These ignore the "error reports" created if the project crashes
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# This is VERY important—it ignores your secret keys so they don't get stolen
.env*
.env.local

# This ignores the settings for the company that hosts your website
.vercel

# These ignore technical helper files for the coding language
*.tsbuildinfo
next-env.d.ts

# This ignores the secret settings for your login and security system
/.clerk/